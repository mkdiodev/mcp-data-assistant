# ============================================
# MCP Data Assistant - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# ============================================

# --- AI Configuration (LM Studio) ---
# Base URL for LM Studio local server
AI_BASE_URL=http://localhost:1234/v1
# API Key (use 'lm-studio' for LM Studio)
AI_API_KEY=lm-studio
# Model name (optional, LM Studio auto-detects)
AI_MODEL=local-model

# --- Database Configuration (SQL Server) ---
# Server name (e.g., localhost\\SQLEXPRESS or SERVER_NAME\\INSTANCE)
DB_SERVER=localhost\\SQLEXPRESS
# Database name
DB_NAME=your_database_name
# Username (use SQL Authentication or leave empty for Windows Auth)
DB_USER=sa
# Password
DB_PASSWORD=your_password_here
# Use Windows Authentication (True/False)
DB_USE_WINDOWS_AUTH=False

# --- Application Settings ---
# Data folder path (relative to project root)
DATA_FOLDER=./data
# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO